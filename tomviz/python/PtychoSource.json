{
  "schemaVersion": 2,
  "name": "PtychoSource",
  "label": "Ptycho Source",
  "widget": "PtychoWidget",
  "description": "Load and stack ptychography reconstruction data into a tilt series. Reads .npy object and probe files from a ptycho directory, extracts phase and amplitude, applies background removal, pads to uniform size, and optionally rotates to the Tomviz convention.",
  "outputs": [
    {"name": "object", "type": "TiltSeries", "persistent": true},
    {"name": "probe", "type": "TiltSeries", "persistent": true}
  ],
  "parameters": [
    {
      "name": "ptycho_dir",
      "label": "Ptycho Directory",
      "type": "directory",
      "default": ""
    },
    {
      "name": "output_info_file",
      "label": "Output Info File",
      "type": "file",
      "default": ""
    },
    {
      "name": "rotate_datasets",
      "label": "Rotate Datasets",
      "type": "bool",
      "default": true
    },
    {
      "name": "sid_list",
      "label": "Scan IDs (JSON)",
      "type": "string",
      "default": "[]"
    },
    {
      "name": "version_list",
      "label": "Versions (JSON)",
      "type": "string",
      "default": "[]"
    },
    {
      "name": "angle_list",
      "label": "Angles (JSON)",
      "type": "string",
      "default": "[]"
    },
    {
      "name": "ui_state",
      "label": "UI Settings",
      "type": "string",
      "default": "{}"
    }
  ]
}
